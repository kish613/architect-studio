{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "installCommand": "npm install",
  "functions": {
    "api/models/*/generate-isometric.ts": {
      "maxDuration": 120,
      "includeFiles": "lib/**,shared/**"
    },
    "api/models/*/generate-pascal.ts": {
      "maxDuration": 120,
      "includeFiles": "lib/**,shared/**"
    },
    "api/models/*/generate-3d.ts": {
      "maxDuration": 120,
      "includeFiles": "lib/**,shared/**"
    },
    "api/models/*/generate-3d-trellis.ts": {
      "maxDuration": 120,
      "includeFiles": "lib/**,shared/**"
    },
    "api/models/*/retexture.ts": {
      "maxDuration": 120,
      "includeFiles": "lib/**,shared/**"
    },
    "api/floorplans/*/generate-from-image.ts": {
      "maxDuration": 120,
      "includeFiles": "lib/**,shared/**"
    },
    "api/**/*.ts": {
      "maxDuration": 60,
      "includeFiles": "lib/**,shared/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
